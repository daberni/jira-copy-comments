{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "short_name": "__MSG_appShortName__",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "version": "2.0.0",
  "icons": {
    "128": "icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "jira-clipboard-helper@daberni.github",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.atlassian.net/*"
      ],
      "js": [
        "script.user.js"
      ],
      "css": [
        "css.user.css"
      ]
    }
  ],
  "permissions": [
    "clipboardWrite"
  ]
}
